<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <View
        android:id="@+id/viewHeaderStatus"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#81C784"
        app:layout_constraintTop_toTopOf="parent"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/cvIconoWrapper"
        android:layout_width="100dp"
        android:layout_height="100dp"
        app:cardCornerRadius="50dp"
        app:cardElevation="6dp"
        app:layout_constraintBottom_toBottomOf="@id/viewHeaderStatus"
        app:layout_constraintTop_toBottomOf="@id/viewHeaderStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivIconoDetalle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@android:drawable/ic_menu_camera"
            android:padding="24dp"
            android:scaleType="centerInside"
            android:tint="#81C784"/>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvDetalleNombre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nombre del Equipo"
        android:textSize="24sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:textColor="#212121"
        android:gravity="center"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/cvIconoWrapper"/>

    <TextView
        android:id="@+id/tvDetalleId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ID: 123456"
        android:gravity="center"
        android:fontFamily="sans-serif"
        android:textColor="#757575"
        app:layout_constraintTop_toBottomOf="@id/tvDetalleNombre"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        app:layout_constraintTop_toBottomOf="@id/tvDetalleId">

        <TextView
            android:text="Ubicación"
            android:textSize="12sp"
            android:textColor="#81C784"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:textAllCaps="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/tvDetalleUbicacion"
            android:text="Laboratorio 1"
            android:textSize="18sp"
            android:textColor="#424242"
            android:fontFamily="sans-serif"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Fecha de Registro"
            android:textSize="12sp"
            android:textColor="#81C784"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:textAllCaps="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/tvDetalleFecha"
            android:text="08 Mar 2026"
            android:textSize="18sp"
            android:textColor="#424242"
            android:fontFamily="sans-serif"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Notas de Auditoría"
            android:textSize="12sp"
            android:textColor="#81C784"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:textAllCaps="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>
        <TextView
            android:id="@+id/tvDetalleNotas"
            android:text="Sin observaciones pendientes en este equipo."
            android:textSize="16sp"
            android:textColor="#616161"
            android:fontFamily="sans-serif"
            android:background="#FAFAFA"
            android:padding="12dp"
            android:lineSpacingExtra="4dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>