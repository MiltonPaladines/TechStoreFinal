<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF"
    android:fontFamily="sans-serif"
    tools:context=".AddEditActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Registro de Equipo"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="24dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:hint="Nombre del Equipo">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etNombre"
            android:inputType="textCapWords"
            android:fontFamily="sans-serif"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:hint="Ubicación Específica">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etUbicacion"
            android:inputType="textCapSentences"
            android:fontFamily="sans-serif"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Estado actual:"
        android:textSize="14sp"
        android:textColor="#757575"
        android:fontFamily="sans-serif"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/spEstado"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:padding="8dp"
        android:background="@drawable/abc_spinner_textfield_background_material"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:hint="Notas o detalles técnicos">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etNotas"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:gravity="top"
            android:fontFamily="sans-serif"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btnGuardar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="GUARDAR CAMBIOS"
        android:textSize="16sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="32dp"
        app:cornerRadius="8dp"
        android:backgroundTint="#81C784"/> </LinearLayout>